---
import { Image } from 'astro:assets';
import type { ImageMetadata } from "astro";

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/*.{jpeg,jpg,png,gif,webp}');
const videos = import.meta.glob<{ default: string }>('/src/assets/*.{mp4,webm}', { eager: true });

const { url, title, description, cover } = Astro.props;

const fullUrl = url.startsWith('/') ? url : `/works/${url}`;
const isVideo = cover && (cover.endsWith('.mp4') || cover.endsWith('.webm'));
---
<div class="work-card">
    <a href={fullUrl} class="work-content">
        {cover && !isVideo && images[cover] && (
            <div class="work-image">
                <Image src={images[cover]()} alt={title} class="work-thumbnail" />
            </div>
        )}
        {cover && isVideo && videos[cover] && (
            <div class="work-image">
                <video src={videos[cover].default} autoplay loop muted playsinline class="work-thumbnail"></video>
            </div>
        )}
        <div class="work-info">
            <h3>{title}</h3>
            <p>{description}</p>
            <span class="read-more">Ver trabalho -></span>
        </div>
    </a>
</div>

<style>
.work-card {
    border: 1px solid #000000;
    border-radius: 8px;
    padding: 1rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    margin-bottom: 1rem;
}

html.dark .work-card {
    /* background-color: #1a1a1a; */
    border-color: #ffffff;
}

