---
import BaseLayout from "../layouts/BaseLayout.astro";

const allPosts = Object.values(import.meta.glob('./posts/*.md', { eager: true }));

// Extrai e formata a data para ordenação
const parseDate = (dateStr: any) => {
    if (!dateStr) return new Date(0);
    const str = String(dateStr);
    
    // Suporte para o formato brasileiro: DD-MM-YYYY
    const parts = str.split('-');
    if (parts.length === 3 && parts[2].length === 4) {
        return new Date(`${parts[2]}-${parts[1]}-${parts[0]}T00:00:00`);
    }
    
    // Fallback para YYYY-MM-DD
    const isoParts = str.split('-');
    if (isoParts.length === 3 && isoParts[0].length === 4) {
        return new Date(`${isoParts[0]}-${isoParts[1]}-${isoParts[2]}T00:00:00`);
    }
    
    return new Date(dateStr);
};

// Ordena os posts: mais recentes primeiro
const sortedPosts = allPosts.sort((a: any, b: any) => {
    return parseDate(b.frontmatter.pubDate).getTime() - parseDate(a.frontmatter.pubDate).getTime();
});

// Agrupa os posts por ano
const postsByYear = sortedPosts.reduce((acc: any, post: any) => {
    const year = parseDate(post.frontmatter.pubDate).getFullYear().toString();
    if (!acc[year]) acc[year] = [];
    acc[year].push(post);
    return acc;
}, {});

// Lista de anos para iterar (do maior para o menor)
const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));

const pageTitle = "Blog";
---
<BaseLayout pageTitle={pageTitle} baseText="">
    <div class="blog-container">
        {years.map((year) => (
            <div class="year-group">
                <h2 class="year-heading">{year}</h2>
                <ul class="post-list">
                    {postsByYear[year].map((post: any) => (
                        <li>
                            <a href={post.url}>
                                <span class="post-date">
                                    {String(post.frontmatter.pubDate).slice(0, 10)}
                                </span>
                                <span class="post-title">
                                    {post.frontmatter.title}
                                </span>
                            </a>    
                        </li>
                    ))}
                </ul>
            </div>
        ))}
    </div>
</BaseLayout>

