---
import BaseLayout from "../layouts/BaseLayout.astro"

const allPosts = Object.values(import.meta.glob('./projects/*.md', { eager: true }))
---

<BaseLayout pageTitle="Projetos" baseText="in progress...">
    <ul>
        {allPosts.map((post: any) => (
                <li>
                    <a href={`${post.url}/`}>
                        {post.frontmatter.title}
                    </a>    
            </li>
        ))}
    </ul>

</BaseLayout>